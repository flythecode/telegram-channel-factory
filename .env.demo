# Demo runtime configuration for Telegram Channel Factory

# Application
APP_NAME=Telegram Channel Factory
APP_ENV=staging
DEBUG=false
API_V1_PREFIX=/api/v1
API_HOST=127.0.0.1
API_PORT=8000

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tcf

# Runtime mode
RUNTIME_MODE=demo

# Publisher backend
# Demo mode stays on stub to prevent accidental real sends.
PUBLISHER_BACKEND=stub
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_TOKEN_FILE=
TELEGRAM_REQUEST_TIMEOUT_SECONDS=20

# LLM layer
# Demo/staging stays on stub unless explicitly switched to a real provider in a non-tracked env file.
LLM_PROVIDER=stub
LLM_API_KEY=
LLM_API_KEY_FILE=
LLM_MODEL_DEFAULT=stub-default
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
LLM_ROUTING_STRATEGY=single-model
LLM_FAILOVER_STRATEGY=graceful-degradation
LLM_FALLBACK_PROVIDER=
LLM_FALLBACK_MODEL=

# Worker
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_BATCH_LIMIT=100
GENERATION_WORKER_POOL_SIZE=4
GENERATION_JOB_BATCH_LIMIT=100
