# Telegram live test configuration for Telegram Channel Factory

# Application
APP_NAME=Telegram Channel Factory
APP_ENV=staging
DEBUG=false
API_V1_PREFIX=/api/v1
API_HOST=127.0.0.1
API_PORT=8000

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tcf

# Runtime mode
RUNTIME_MODE=live

# Publisher backend
PUBLISHER_BACKEND=telegram
TELEGRAM_BOT_TOKEN_FILE=/run/secrets/tcf/telegram_bot_token
# SET_IN_LOCAL_UNTRACKED_ENV_ONLY
TELEGRAM_REQUEST_TIMEOUT_SECONDS=20

# Worker
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_BATCH_LIMIT=100
GENERATION_WORKER_POOL_SIZE=4
GENERATION_JOB_BATCH_LIMIT=100

# Notes
# 1. Do not put real tokens into this tracked file.
# 2. Store live secrets in an untracked file such as `.env.live`.
# 3. In channel data, use a real channel_id or channel_username.
# 4. Make sure the bot has permission to post into the target channel.
