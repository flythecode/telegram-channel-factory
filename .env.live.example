# Live runtime template for Telegram Channel Factory
# Copy to a NON-tracked file such as `.env.live` and fill secrets there.
# Do not commit `.env.live` or any real token file.

APP_NAME=Telegram Channel Factory
APP_ENV=prod
DEBUG=false
API_V1_PREFIX=/api/v1
API_HOST=0.0.0.0
API_PORT=8000

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tcf

RUNTIME_MODE=live
PUBLISHER_BACKEND=telegram
# Preferred production path: keep the token in a separate untracked file.
# Local compose example: /run/secrets/tcf/telegram_bot_token
# Host example: /etc/telegram-channel-factory/secrets/telegram_bot_token
TELEGRAM_BOT_TOKEN_FILE=/run/secrets/tcf/telegram_bot_token
# Optional fallback for local-only emergency use. Prefer TELEGRAM_BOT_TOKEN_FILE.
TELEGRAM_BOT_TOKEN=
TELEGRAM_REQUEST_TIMEOUT_SECONDS=20

# Separate LLM generation layer
LLM_PROVIDER=openai
# Local compose example: /run/secrets/tcf/llm_api_key
# Host example: /etc/telegram-channel-factory/secrets/llm_api_key
LLM_API_KEY_FILE=/run/secrets/tcf/llm_api_key
# Optional fallback for local-only emergency use. Prefer LLM_API_KEY_FILE.
LLM_API_KEY=
LLM_MODEL_DEFAULT=gpt-4.1-mini
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
LLM_ROUTING_STRATEGY=by-operation
LLM_FAILOVER_STRATEGY=fallback-provider
LLM_FALLBACK_PROVIDER=stub
LLM_FALLBACK_MODEL=stub-fallback
# Example mapping for the first production-ready routing policy.
# Keep profile values provider-specific and untracked if they are sensitive.
LLM_PROFILE_FAST_IDEAS=gpt-4.1-mini
LLM_PROFILE_PLANNER_BALANCED=gpt-4.1-mini
LLM_PROFILE_WRITER_BALANCED=gpt-4.1-mini
LLM_PROFILE_WRITER_STRONG=gpt-4.1
LLM_PROFILE_REWRITE_FAST=gpt-4.1-mini
LLM_PROFILE_REWRITE_BALANCED=gpt-4.1-mini
LLM_PROFILE_PLANNER_PREMIUM=gpt-4.1
LLM_PROFILE_WRITER_PREMIUM=gpt-4.1
LLM_PROFILE_EDITOR_PREMIUM=gpt-4.1

WORKER_POLL_INTERVAL_SECONDS=5
WORKER_BATCH_LIMIT=100
GENERATION_WORKER_POOL_SIZE=4
GENERATION_JOB_BATCH_LIMIT=100
