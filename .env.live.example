# Live runtime template for Telegram Channel Factory
# Copy to a NON-tracked file such as `.env.live` and fill secrets there.
# Do not commit `.env.live` or any real token file.

APP_NAME=Telegram Channel Factory
APP_ENV=prod
DEBUG=false
API_V1_PREFIX=/api/v1
API_HOST=0.0.0.0
API_PORT=8000

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tcf

RUNTIME_MODE=live
PUBLISHER_BACKEND=telegram
# Preferred production path: keep the token in a separate untracked file.
# Local compose example: /run/secrets/tcf/telegram_bot_token
# Host example: /etc/telegram-channel-factory/secrets/telegram_bot_token
TELEGRAM_BOT_TOKEN_FILE=/run/secrets/tcf/telegram_bot_token
# Optional fallback for local-only emergency use. Prefer TELEGRAM_BOT_TOKEN_FILE.
TELEGRAM_BOT_TOKEN=
TELEGRAM_REQUEST_TIMEOUT_SECONDS=20

WORKER_POLL_INTERVAL_SECONDS=5
WORKER_BATCH_LIMIT=100
