# Application
APP_NAME=Telegram Channel Factory
APP_ENV=dev
DEBUG=true
API_V1_PREFIX=/api/v1
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tcf

# Runtime mode
# stub = safe local/dev mode
# demo = safe demo mode (still stub publisher)
# live = real Telegram send mode
RUNTIME_MODE=stub

# Publisher backend
PUBLISHER_BACKEND=stub
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_TOKEN_FILE=
# keep live tokens only in untracked env files (for example `.env.live`)
# for production prefer TELEGRAM_BOT_TOKEN_FILE + separate secret file over inline TELEGRAM_BOT_TOKEN
TELEGRAM_REQUEST_TIMEOUT_SECONDS=20
# for live Telegram mode, channel must provide channel_id or channel_username

# LLM layer
LLM_PROVIDER=stub
LLM_API_KEY=
LLM_API_KEY_FILE=
LLM_MODEL_DEFAULT=stub-default
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
LLM_ROUTING_STRATEGY=single-model
LLM_FAILOVER_STRATEGY=graceful-degradation
LLM_FALLBACK_PROVIDER=
LLM_FALLBACK_MODEL=
# optional next-step routing profiles for by-operation strategy
LLM_PROFILE_FAST_IDEAS=
LLM_PROFILE_PLANNER_BALANCED=
LLM_PROFILE_WRITER_BALANCED=
LLM_PROFILE_WRITER_STRONG=
LLM_PROFILE_REWRITE_FAST=
LLM_PROFILE_REWRITE_BALANCED=
LLM_PROFILE_PLANNER_PREMIUM=
LLM_PROFILE_WRITER_PREMIUM=
LLM_PROFILE_EDITOR_PREMIUM=

# Worker
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_BATCH_LIMIT=100
GENERATION_WORKER_POOL_SIZE=4
GENERATION_JOB_BATCH_LIMIT=100
